<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="700" viewBox="0 0 1200 700">
  <rect width="1200" height="700" fill="#3d2512"/>
  <rect x="0" y="0" width="1200" height="700" fill="url(#g)"/>
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2C1A0E"/>
      <stop offset="100%" style="stop-color:#5a3520"/>
    </linearGradient>
  </defs>
  <text x="600" y="330" font-family="Georgia, serif" font-size="28" fill="rgba(245,236,215,0.25)" text-anchor="middle">
    Replace with your project photo
  </text>
  <text x="600" y="375" font-family="Georgia, serif" font-size="16" fill="rgba(184,134,11,0.4)" text-anchor="middle">
    /public/images/hero-bg.jpg
  </text>
</svg>
